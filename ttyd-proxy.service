[Unit]
Description=ttyd Telegram Mini App Auth Proxy
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.hermes/ttyd-proxy
ExecStart=/usr/bin/env node %h/.hermes/ttyd-proxy/server.js
EnvironmentFile=%h/.hermes/ttyd-proxy/.env
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
